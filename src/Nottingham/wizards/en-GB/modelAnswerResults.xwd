<wizard menus="Interactivity">  <pageWizard remove="true" duplicate="false">    <newNodes>      <modelAnswerResults><![CDATA[<modelAnswerResults name="Enter Page Title" text=""     modelAnswerPage="true" highlightPage="false" documentationPage="false" dataPageLink="true"      panelWidth="Medium" panelWidthCustom="50" panelHeight="fill" align="Right" panelStyle="false" removeTxt="false"	  copyBtn2Label="Copy" downloadTxt="Download" pageTxt="Page" notViewed="Page not viewed"	  ></modelAnswerResults>]]></modelAnswerResults>    </newNodes>  </pageWizard>  <!-- Model Answer Results PAGE ================================ -->  <modelAnswerResults menu="Interactivity" menuItem="Model Answer Results" hint="Displays collated results from all viewed Model Answer pages which can then be reviewed and copied or downloaded." icon="icFolderPage" thumb="thumbs/modelAnswerResult.jpg" remove="true" wiki="https://xerte.org.uk/wiki/doku.php?id=interactivity_model_answer_results_page" >    <name label="Page Title" type="TextInput" wysiwyg="true"/>    <text label="Page Text" type="TextArea" height="280" placeholder="Enter text for the page here" mandatory="true" defaultValue="" condition="panelWidth!='Full'||(removeTxt!='true'&amp;&amp;removeTxt!=undefined)"/>    <layoutGroup label="Page Layout" type="group">      <panelWidth label="Panel Width" options="Small,Medium,Large,Full,Custom" type="ComboBox" data="Small,Medium,Large,Full,Custom" defaultValue="Medium" mandatory="true" conditionTrigger="true"/>      <panelWidthCustom label="Custom Width (%)" type="NumericStepper" min="10" max="90" step="1" defaultValue="50" condition="panelWidth=='Custom'"/>      <panelHeight label="Panel Height" options="Fill Space,Fit Content" type="ComboBox"  data="fill,fit" defaultValue="fill" condition="textTop==undefined&amp;&amp;textBottom==undefined&amp;&amp;panelStyle!='true'&amp;&amp;(panelWidth!='Full'||removeTxt!='false')"/>      <align label="Panel Position" options="Right,Left" type="ComboBox" data="Right,Left" defaultValue="Right" condition="panelWidth!='Full'"/>      <panelStyle label="Remove Panel Style" type="CheckBox" defaultValue="false" conditionTrigger="true"/>      <removeTxt label="Remove Page Text" type="CheckBox" defaultValue="true" conditionTrigger="true" condition="panelWidth=='Full'"/>    </layoutGroup>    <info><![CDATA[<p>By default, the results from all viewed Model Answer pages will be displayed on this page. To collate results from a limited number of pages instead, add new 'Page Results' to specify the pages used.</p>]]></info>    <textTopGroup label="Text Above Panel" type="group" optional="true">      <textTop label="Text" type="TextArea" height="100" optional="true" conditionTrigger="true"/>      <textTopWidth label="Full Width" type="CheckBox" optional="true" defaultValue="false" condition="panelWidth!='Full'"/>    </textTopGroup>    <textBelowGroup label="Text Below Panel" type="group" optional="true">      <textBottom label="Text" type="TextArea" height="100" optional="true" conditionTrigger="true"/>      <textBottomWidth label="Full Width" type="CheckBox" optional="true" defaultValue="false" condition="panelWidth!='Full'"/>    </textBelowGroup>    <dataGroup label="Customise Results" type="group" optional="true" tooltip="Customise the type of data from viewed pages that will be shown on this page">      <dataPageLink label="Include Link" type="CheckBox" optional="true" condition="dataPageH=='true'||dataPageH==undefined" defaultValue="false" mandatory="true" tooltip="Include links to pages where the collated data originated from"/>      <collatedPages label="Page Types" type="group" optional="true" cols="2" info="&lt;p&gt;Select the types of page to include in the collated data shown on this page.&lt;br/&gt;These page selections will be overridden if specific pages are added via the new 'Page Results' option below.&lt;/p&gt;">        <modelAnswer label="Model Answer" type="CheckBox" defaultValue="true" optional="true"/>        <textHighlight label="Highlight Text / Note Taking" type="CheckBox" defaultValue="false" optional="true"/>      </collatedPages>      <dataGroup2 label="Displayed Data" type="group" optional="true" info="Select the data from each page that will be shown here.">        <dataPageGroup label="Page" type="group" optional="true">          <dataPageH label="Title" type="CheckBox" conditionTrigger="true" optional="true" defaultValue="true"/>          <dataPageTxt label="Text" type="CheckBox" optional="true" defaultValue="false"/>          <dataPageFb label="Feedback" type="CheckBox" optional="true" defaultValue="true"/>          <dataPageTopTxt label="Text Above" type="CheckBox" optional="true" defaultValue="false"/>          <dataPageBottomTxt label="Text Below" type="CheckBox" optional="true" defaultValue="false"/>        </dataPageGroup>        <dataQuestionGroup label="Exercise" type="group" optional="true">          <dataQuestionGroup_modelAnswer type="group" label="Model Answer Pages" optional="true">            <dataQuestionH label="Titles" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionTxt label="Prompt" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionAnswer label="Response" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionFb label="Feedback" type="CheckBox" optional="true" defaultValue="true"/>          </dataQuestionGroup_modelAnswer>          <dataQuestionGroup_textHighlight type="group" label="Highlight Text / Note Taking Pages" optional="true">            <dataQuestionH_textHighlight label="Titles" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionTxt_textHighlight label="Initial Text" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionAnswer_textHighlight label="Notes" type="CheckBox" optional="true" defaultValue="true"/>            <dataQuestionFb_textHighlight label="Suggested Text" type="CheckBox" optional="true" defaultValue="true"/>          </dataQuestionGroup_textHighlight>        </dataQuestionGroup>      </dataGroup2>    </dataGroup>    <unviewed label="Include Unviewed Pages" type="CheckBox" defaultValue="true" conditionTrigger="true" optional="true" tooltip="Include data from unviewed pages"/>    <copyPaste label="Copy Button" type="CheckBox" defaultValue="true" optional="true" tooltip="Include a button that allows users to easily select &amp; copy their responses"/>    <downloadGroup label="Download Button" type="group" optional="true" tooltip="Include a button that allows users to download a copy their responses">      <showDownload label="Include button" type="CheckBox" optional="true" defaultValue="true" conditionTrigger="true"/>      <filename condition="showDownload!='false'" label="Filename (without extension)" type="TextInput" defaultValue="model_answer_results" optional="true"/>      <fileOrientation condition="showDownload!='false'" label="File orientation" data="portrait,landscape" type="ComboBox" options="Portrait,Landscape" width="120" defaultValue="portrait" optional="true" tooltip="Orientation of downloaded file"/>    </downloadGroup>    <copypasteinfo label="Instructions" type="TextArea" height="50" defaultValue="Note: Click the 'Select Text' button to highlight the text on the right and then Ctrl + C to copy this text to the clipboard. You can then paste (Ctrl + V) into another application such as Open Office, Word or an email to save for future reference." optional="true" deprecated="This property is deprecated - use the 'Copy Button' optional property to add a button that copies responses to the clipboard" />    <copyBtn2Label label="Copy Button Label" type="TextInput" wysiwyg="true" language="true" mandatory="true" defaultValue="Copy"/>    <downloadTxt label="Download Button Label" type="TextInput" condition="showDownload!='false'" mandatory="true" language="true" defaultValue="Download" />    <pageTxt label="Page Number Text" type="TextInput" condition="unviewed=='true'" mandatory="true" language="true" defaultValue="Page" />    <notViewed label="Not Viewed Text" type="TextInput" condition="unviewed=='true'" mandatory="true" language="true" defaultValue="Page not viewed" />    <copyBtnLabel label="Select Button Label" type="TextInput" wysiwyg="true" language="true" deprecated="This property is no longer in use"/>    <newNodes>        <modelAnswerPage><![CDATA[<modelAnswerPage name="Page" page=""/>]]></modelAnswerPage>    </newNodes>  </modelAnswerResults>  <modelAnswerPage menuItem="Page Results" icon="icTextArea" remove="true">    <name label="Label" type="TextInput" wysiwyg="false" tooltip="The label only appears in the editor's project structure panel and is not shown in the project itself. Unique and meaningful labels can be used to make pages easier to locate for editing at a later date."/>    <page label="Page" type="pageList" pageTypes="modelAnswer,textHighlight" tooltip="The data from this page will be shown on this page"/>  </modelAnswerPage></wizard>